{
  "name": "getcourse-api",
  "version": "0.2.0",
  "description": "TypeScript SDK для GetCourse API",
  "keywords": [
    "getcourse",
    "api",
    "sdk",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "author": "NiktarioN",
  "license": "MIT",
  "homepage": "https://github.com/NiktarioN/getcourse-api",
  "repository": {
    "type": "git",
    "url": "https://github.com/NiktarioN/getcourse-api.git"
  },
  "bugs": {
    "url": "https://github.com/NiktarioN/getcourse-api/issues"
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "eslint . --max-warnings=0 && tsc -p tsconfig.app.json && tsc -p tsconfig.mjs.json"
  },
  "dependencies": {
    "axios": "^1.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.2",
    "eslint-config-airbnb-extended": "^3.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-perfectionist": "^5.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
